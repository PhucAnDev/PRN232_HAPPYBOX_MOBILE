# Shared backend with PRN232_HAPPYBOX_FE
EXPO_PUBLIC_API_URL=https://prn232.onrender.com/api

# Set to true only when you want FE mobile to stay on local mock data.
EXPO_PUBLIC_USE_MOCK_API=false

# Notes:
# - Physical device + local backend: use your LAN IP, for example http://192.168.1.10:5000/api
# - Android emulator + local backend: use http://10.0.2.2:5000/api
